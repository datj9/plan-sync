{
  "name": "plan-sync",
  "version": "0.0.1",
  "description": "Share task status across Claude Code / Codex sessions via git",
  "type": "module",
  "bin": {
    "plan-sync": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepare": "node -e \"try{require('child_process').execFileSync('git',['config','core.hooksPath','hooks'],{stdio:'ignore'})}catch(e){}\""
  },
  "dependencies": {
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
